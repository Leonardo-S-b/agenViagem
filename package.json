    },
    "devDependencies": {
        "@types/express": "^4.17.17",
        "@types/node": "^20.0.0",
        "@types/nodemailer": "^8.0.0",
        "bruno": "^0.0.0",
        "prisma": "^5.0.0",
        "ts-node": "^10.9.1",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.0.0"
    }
